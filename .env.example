# Atlas OS local configuration placeholders.
# Copy to .env for local development. Do not commit real credentials.

ATLAS_ENV=development
ATLAS_DB_PATH=.atlas/atlas.db
ATLAS_LOG_LEVEL=INFO
ATLAS_OUTPUT_DIR=.atlas/output

# External service keys are intentionally blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MARKET_DATA_API_KEY=

# Optional GreenRock market data settings.
# Default GreenRock mode remains mock and requires no provider.
# Real mode fails safely unless these are configured locally.
ATLAS_GREENROCK_DEFAULT_DATA_MODE=mock
ATLAS_MARKET_DATA_PROVIDER=
ATLAS_GREENROCK_REAL_TICKERS=
