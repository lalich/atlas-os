#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "Atlas dev bootstrap"
echo "project_root: $ROOT"

if [ ! -d ".venv" ]; then
  echo "Creating .venv"
  python3 -m venv .venv
fi

# shellcheck disable=SC1091
source ".venv/bin/activate"
PYTHON="$ROOT/.venv/bin/python"

echo "Installing Atlas OS editable package with market-data extras"
"$PYTHON" -m pip install -e ".[market-data]"
cat > ".venv/bin/atlas" <<'SH'
#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"
cd "$ROOT"
exec "$ROOT/.venv/bin/python" -m atlas_os.cli "$@"
SH
chmod +x ".venv/bin/atlas"

if [ ! -f ".env" ]; then
  if [ -f ".env.example" ]; then
    cp ".env.example" ".env"
  else
    printf "ATLAS_MARKET_DATA_PROVIDER=yfinance\n" > ".env"
  fi
  if ! grep -q "^ATLAS_MARKET_DATA_PROVIDER=" ".env"; then
    printf "\nATLAS_MARKET_DATA_PROVIDER=yfinance\n" >> ".env"
  fi
fi

"$PYTHON" -c "import atlas_os"
"$PYTHON" -m atlas_os.cli doctor

cat <<'NEXT'

Next commands:
  bin/atlas serve
  bin/atlas agents run
  bin/atlas morning-brief

If a stale atlas launcher fails, use:
  .venv/bin/python -m atlas_os.cli serve
NEXT
